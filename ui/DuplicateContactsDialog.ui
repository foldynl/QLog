   <item>
    <layout class="QHBoxLayout" name="buttonLayout">
     <item>
      <widget class="QPushButton" name="autoSelectButton">
       <property name="toolTip">
        <string>Automatically check the second contact in each duplicate pair (the one with the higher ID) for removal.</string>
       </property>
       <property name="text">
        <string>Auto-Select Duplicates</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="unselectAllButton">
       <property name="toolTip">
        <string>Uncheck all rows so you can manually select which contacts to merge or remove.</string>
       </property>
       <property name="text">
        <string>Unselect All</string>
       </property>
      </widget>
     </item>
